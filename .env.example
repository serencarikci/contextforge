CONTEXTFORGE_APP__NAME=contextforge-api
CONTEXTFORGE_APP__ENVIRONMENT=local
CONTEXTFORGE_APP__DEBUG=true
CONTEXTFORGE_APP__VERSION=0.1.0

CONTEXTFORGE_API__HOST=0.0.0.0
CONTEXTFORGE_API__PORT=8000
CONTEXTFORGE_API__ROOT_PATH=
CONTEXTFORGE_API__CORS_ORIGINS=[]
CONTEXTFORGE_API__DOCS_ENABLED=true

CONTEXTFORGE_POSTGRES__HOST=localhost
CONTEXTFORGE_POSTGRES__PORT=5432
CONTEXTFORGE_POSTGRES__USER=contextforge
CONTEXTFORGE_POSTGRES__PASSWORD=contextforge_dev_password
CONTEXTFORGE_POSTGRES__DATABASE=contextforge
CONTEXTFORGE_POSTGRES__POOL_SIZE=5
CONTEXTFORGE_POSTGRES__MAX_OVERFLOW=10
CONTEXTFORGE_POSTGRES__ECHO=false

CONTEXTFORGE_REDIS__URL=redis://localhost:6379/0
CONTEXTFORGE_REDIS__TIMEOUT_SECONDS=2.0

CONTEXTFORGE_QDRANT__URL=http://localhost:6333
CONTEXTFORGE_QDRANT__API_KEY=
CONTEXTFORGE_QDRANT__TIMEOUT_SECONDS=3.0
CONTEXTFORGE_QDRANT__COLLECTION_NAME=document_chunks

CONTEXTFORGE_EMBEDDING__PROVIDER=hashing
CONTEXTFORGE_EMBEDDING__MODEL=contextforge-multilingual-hash-v1
CONTEXTFORGE_EMBEDDING__DIMENSIONS=384
CONTEXTFORGE_EMBEDDING__BATCH_SIZE=32
CONTEXTFORGE_EMBEDDING__MAX_RETRIES=3
CONTEXTFORGE_EMBEDDING__RETRY_BACKOFF_SECONDS=0.5
CONTEXTFORGE_EMBEDDING__BASE_URL=https://api.openai.com/v1
CONTEXTFORGE_EMBEDDING__API_KEY=
CONTEXTFORGE_EMBEDDING__TIMEOUT_SECONDS=30.0

CONTEXTFORGE_MINIO__ENDPOINT=localhost:9000
CONTEXTFORGE_MINIO__ACCESS_KEY=contextforge_minio
CONTEXTFORGE_MINIO__SECRET_KEY=contextforge_minio_secret
CONTEXTFORGE_MINIO__BUCKET=contextforge-documents
CONTEXTFORGE_MINIO__SECURE=false
CONTEXTFORGE_MINIO__REGION=us-east-1
CONTEXTFORGE_MINIO__TIMEOUT_SECONDS=3.0

CONTEXTFORGE_LOGGING__LEVEL=INFO
CONTEXTFORGE_LOGGING__FORMAT=console
CONTEXTFORGE_LOGGING__SERVICE_NAME=contextforge-api

CONTEXTFORGE_SECURITY__SECRET_KEY=change-me-local-only-not-for-production
CONTEXTFORGE_SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=60
CONTEXTFORGE_SECURITY__ALGORITHM=HS256
